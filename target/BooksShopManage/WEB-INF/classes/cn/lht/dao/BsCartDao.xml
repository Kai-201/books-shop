<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.lht.dao.BsCartDao">
    <resultMap type="cn.lht.entity.BsCart" id="BsCartMap">
        <result property="bsCartId" column="bs_cartId" />
        <result property="bsUserId" column="bs_userId" />
        <result property="bsIsCheck" column="bs_isCheck" />
        <result property="bsGoodsId" column="bs_goodsId" />
        <result property="bsCartNum" column="bs_cartNum" />
    </resultMap>

    <select id="queryByUserId" resultMap="BsCartMap">
        select * from books_shop.bs_carts where bs_userId = #{bsUserId}
    </select>

    <select id="queryByUserAndGoods" resultMap="BsCartMap">
        select * from books_shop.bs_carts where bs_userId = #{bsUserId} and bs_goodsId = #{bsGoodsId}
    </select>

    <insert id="insert" keyProperty="bsCartId" useGeneratedKeys="true">
        insert into books_shop.bs_carts(bs_userId, bs_isCheck, bs_goodsId, bs_cartNum)
        values(#{bsUserId}, #{bsIsCheck}, #{bsGoodsId}, #{bsCartNum})
    </insert>

    <update id="update">
        update books_shop.bs_carts
        set bs_isCheck = #{bsIsCheck}, bs_cartNum = #{bsCartNum}
        where bs_cartId = #{bsCartId}
    </update>

    <delete id="deleteById">
        delete from books_shop.bs_carts where bs_cartId = #{bsCartId}
    </delete>

    <delete id="deleteByUserId">
        delete from books_shop.bs_carts where bs_userId = #{bsUserId}
    </delete>
</mapper> 